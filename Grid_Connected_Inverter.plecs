    Component {
      Type          CScript
      Name          "Power Theory"
      Show          on
      Position      [865, 725]
      Direction     up
      Flipped       off
      LabelPosition south
      Parameter {
        Variable      "DialogGeometry"
        Value         "[3555 278 1068 877]"
        Show          off
