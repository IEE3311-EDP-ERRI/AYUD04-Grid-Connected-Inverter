    Component {
      Type          CScript
      Name          "Power Theory1"
      Show          on
      Position      [1080, 630]
      Direction     up
      Flipped       off
      LabelPosition south
      Parameter {
        Variable      "DialogGeometry"
        Value         "[3960 334 627 688]"
        Show          off
      }
      Parameter {
        Variable      "NumInputs"
        Value         "[2 2]"
        Show          off
      }
      Parameter {
        Variable      "NumOutputs"
        Value         "2"
