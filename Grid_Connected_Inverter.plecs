  FixedPointDatatypeOverride "1"
  InitializationCommands "% Grid Parameters.\nVbase = 380; % fase-fase RMS.\nV"
"peak = Vbase*sqrt(2)/sqrt(3); % peak. \nfg = 50;\nwg = 2*pi*fg;\n\n% Line Imp"
"edance.\nSCR = 25; % stiff grid. \nXR = 1; % distribution. \nSnom = 3e3;\n\nR"
"g = Vbase^2/(SCR*Snom*sqrt(1 + XR^2));\nLg = XR*Rg/wg;\n\n% Inverter Paramete"
"rs.\nVdc = 700;\nLf = 5e-3;\nRf = 0.1;\nfpwm = 10e3;\nTs = 1/fpwm;\n\n% Curre"
"nt Controller.\nwn = 2*pi*500; \nxi = 0.707; \n\nL = Lg + Lf;\nR = Rg + Rf;\n"
"\nKp = 2*xi*wn*L - R; \nKi = (wn*wn)*L; \n\n% Power Controller.\n% Kpf = 1e-3"
";\n% Kif = 1e-6;\n\nKpf = 1e-3;\nKif = 1e-3;"
