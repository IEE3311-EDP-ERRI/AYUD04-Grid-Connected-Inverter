        Value         "0"
        Show          off
      }
      Parameter {
        Variable      "DirectFeedthrough"
        Value         "1"
        Show          off
      }
      Parameter {
        Variable      "Ts"
        Value         "Ts"
        Show          off
      }
      Parameter {
        Variable      "TerminalBasedSampleTimes"
        Value         "1"
        Show          off
      }
      Parameter {
        Variable      "Parameters"
        Value         ""
        Show          off
      }
      Parameter {
        Variable      "LangStandard"
        Value         "2"
        Show          off
      }
      Parameter {
        Variable      "GnuExtensions"
        Value         "1"
        Show          off
      }
      Parameter {
        Variable      "RuntimeCheck"
        Value         "2"
        Show          off
      }
      Parameter {
        Variable      "HighlightLevel"
        Value         "0"
        Show          off
      }
      Parameter {
        Variable      "Declarations"
        Value         "#include <math.h>\n"
"\n"
"#define pr_m InputSignal(0,0)\n"
"#define qr_m InputSignal(0,1)\n"
"\n"
"#define va_m InputSignal(1,0)\n"
"#define vb_m InputSignal(1,1)\n"
"\n"
"#define ialpha_m InputSignal(2,0)\n"
"#define ibeta_m InputSignal(2,1)\n"
"\n"
"// Inputs.\n"
"float i_alpha, i_beta;\n"
"float pr, qr;\n"
"float va, vb;\n"
"float v_mod;\n"
"\n"
"// Outputs.\n"
"float ir_alpha;\n"
"float ir_beta;\n"
"\n"
"float p;\n"
"float q;"
        Show          off
      }
      Parameter {
        Variable      "StartFcn"
        Value         ""
        Show          off
      }
      Parameter {
        Variable      "OutputFcn"
        Value         "// Assign variables.\n"
"pr = pr_m;\n"
"qr = qr_m;\n"
"\n"
"va = va_m;\n"
"vb = vb_m;\n"
"\n"
"i_alpha = ialpha_m;\n"
"i_beta = ibeta_m;\n"
"\n"
"// Module voltage. \n"
"v_mod = va*va + vb*vb;\n"
"\n"
"// Current References.\n"
"ir_alpha = (pr*va + qr*vb)/v_mod;\n"
"ir_beta = (pr*vb - qr*va)/v_mod;\n"
"\n"
"// Power Calculation.\n"
"p = (3/2)*(va*i_alpha + vb*i_beta);\n"
"q = (3/2)*(vb*i_alpha - va*i_beta);\n"
"\n"
"OutputSignal(0,0) = ir_alpha;\n"
"OutputSignal(0,1) = ir_beta;\n"
"\n"
"OutputSignal(1,0) = p;\n"
"OutputSignal(1,1) = q;"
        Show          off
      }
      Parameter {
        Variable      "UpdateFcn"
        Value         ""
        Show          off
      }
      Parameter {
        Variable      "DerivativeFcn"
        Value         ""
        Show          off
      }
      Parameter {
        Variable      "TerminateFcn"
        Value         ""
        Show          off
      }
      Parameter {
        Variable      "StoreCustomStateFcn"
        Value         ""
        Show          off
      }
      Parameter {
        Variable      "RestoreCustomStateFcn"
        Value         ""
        Show          off
      }
    }
